<style>
  /* Dialog container overrides */
  .application.ol-purify-dialog-v60,
  .application:has(.ol-purify-dialog-v60),
  .application.dialog:has(.ol-purify-dialog-v60) {
    border: none !important;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4) !important;
    background: transparent !important;
  }

  .application.ol-purify-dialog-v60 .window-content,
  .application:has(.ol-purify-dialog-v60) .window-content,
  .application.dialog:has(.ol-purify-dialog-v60) .window-content {
    padding: 12px !important;
    background:
      radial-gradient(circle at 80% 20%, rgba(20, 150, 180, 0.08), transparent 30%),
      radial-gradient(circle at 15% 85%, rgba(20, 150, 180, 0.05), transparent 35%),
      url("systems/ocho-lanzas/assets/parchment-tile.png") repeat !important;
    color: #090c0c !important;
    font-family: "Signika", sans-serif !important;
    border-radius: 12px !important;
    border: 2px solid #090c0c !important;
  }

  .application.ol-purify-dialog-v60 footer,
  .application.ol-purify-dialog-v60 .window-footer,
  .application:has(.ol-purify-dialog-v60) footer,
  .application:has(.ol-purify-dialog-v60) .window-footer,
  .application.dialog:has(.ol-purify-dialog-v60) footer,
  .application.dialog:has(.ol-purify-dialog-v60) .window-footer {
    background: transparent !important;
    border-top: none !important;
    padding: 0 12px 12px !important;
    display: flex;
    justify-content: flex-end;
    gap: 8px;
  }

  .application.ol-purify-dialog-v60 footer button,
  .application.ol-purify-dialog-v60 .window-footer button,
  .application:has(.ol-purify-dialog-v60) footer button,
  .application:has(.ol-purify-dialog-v60) .window-footer button,
  .application.dialog:has(.ol-purify-dialog-v60) footer button,
  .application.dialog:has(.ol-purify-dialog-v60) .window-footer button {
    min-height: 38px !important;
    min-width: 120px !important;
    background: #090c0c !important;
    color: #f6efe8 !important;
    border-radius: 6px !important;
    border: 2px solid #090c0c !important;
    font-family: "Signika", sans-serif !important;
    font-weight: 800 !important;
    box-shadow: 2px 2px 0 rgba(0, 0, 0, 0.15) !important;
    transition: all 0.2s ease !important;
  }

  .application.ol-purify-dialog-v60 footer button:hover,
  .application.ol-purify-dialog-v60 .window-footer button:hover,
  .application:has(.ol-purify-dialog-v60) footer button:hover,
  .application:has(.ol-purify-dialog-v60) .window-footer button:hover,
  .application.dialog:has(.ol-purify-dialog-v60) footer button:hover,
  .application.dialog:has(.ol-purify-dialog-v60) .window-footer button:hover {
    background: #146f6f !important;
    border-color: #146f6f !important;
    color: #fff !important;
    transform: translateY(1px) !important;
    box-shadow: 1px 1px 0 rgba(0,0,0,0.15) !important;
    cursor: pointer !important;
  }

  /* Form content wrapper */
  .ol-purify-dialog-v60 {
    display: flex;
    flex-direction: column;
    gap: 14px;
    box-sizing: border-box;
    border: 3.5px solid #090c0c;
    border-radius: 255px 15px 225px 15px/15px 225px 15px 255px; /* Hand-drawn look */
    padding: 16px;
    background: rgba(244, 232, 220, 0.15);
  }
  .ol-purify-dialog-v60 * {
    box-sizing: border-box;
  }

  /* Header */
  .ol-purify-dialog-header {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 2px;
  }
  .ol-purify-dialog-banner {
    width: 100%;
    background: #090c0c;
    color: #f6efe8;
    padding: 12px 16px;
    text-align: center;
    clip-path: polygon(2% 16%, 10% 8%, 30% 12%, 52% 6%, 76% 12%, 96% 10%, 98% 86%, 90% 94%, 70% 90%, 50% 96%, 24% 92%, 6% 96%, 2% 86%);
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.15);
  }
  .ol-purify-dialog-banner h2 {
    margin: 0;
    font-family: "Brush Script MT", "Segoe Script", "Comic Sans MS", cursive;
    font-size: 24px;
    font-weight: 700;
    letter-spacing: 2px;
  }
  .ol-purify-dialog-subtitle {
    display: block;
    font-size: 13px;
    opacity: 0.85;
    margin-top: 1px;
    font-style: italic;
  }
  .ol-purify-dialog-help {
    margin: 6px 0 0 0;
    font-size: 11.5px;
    color: #146f6f;
    text-align: center;
    font-weight: 600;
  }

  /* Consequence box */
  .ol-purify-dialog-box {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 150px;
    z-index: 10;
  }
  .ol-purify-dialog-box h3 {
    margin: 0 0 4px 0 !important;
    font-size: 13px !important;
    font-weight: 900 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.5px !important;
    color: #146f6f !important;
    z-index: 10;
  }
  .ol-purify-dialog-textarea {
    width: 100%;
    min-height: 100px;
    padding: 10px 12px;
    border: 2px solid #090c0c;
    border-radius: 100px 5px 95px 5px/5px 95px 5px 100px;
    background: #fbf7f4;
    color: #090c0c;
    font-family: inherit;
    font-size: 13px;
    resize: vertical;
    transition: border-color 0.2s ease;
    z-index: 10;
  }
  .ol-purify-dialog-textarea:focus {
    border-color: #146f6f;
    outline: none;
  }
</style>

<form class="ocho-lanzas ol-root ol-purify-dialog-v60" autocomplete="off">
  <header class="ol-purify-dialog-header">
    <div class="ol-purify-dialog-banner">
      <h2>{{localize "OCHO.Purify.Title"}}</h2>
      <span class="ol-purify-dialog-subtitle">{{localize "OCHO.Actions.Purify"}}</span>
    </div>
    <p class="ol-purify-dialog-help"><em>{{localize "OCHO.Purify.Text"}}</em></p>
  </header>

  <section class="ol-purify-dialog-box ol-box">
    <h3>{{localize "OCHO.Purify.ConsequenceLabel"}}</h3>
    <textarea name="consequence" class="ol-purify-dialog-textarea" placeholder="{{localize 'OCHO.Purify.ConsequencePlaceholder'}}"></textarea>
  </section>
</form>
