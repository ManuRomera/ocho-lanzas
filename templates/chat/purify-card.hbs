<article class="ol-roll-card ol-purify-card">
  <header class="ol-roll-hero">
    <div class="ol-roll-header-banner">
      <h4>{{localize "OCHO.Chat.PurifyTitle"}}</h4>
      <span class="ol-roll-subtitle">{{localize "OCHO.Actions.Purify"}}</span>
    </div>
  </header>

  <div class="ol-purify-display-row">
    <div class="ol-purify-seal">☯</div>
    <div class="ol-purify-arrow-display">
      <span class="ol-purify-arrow-label">{{localize "OCHO.Sections.Curse"}}</span>
      <div class="ol-purify-arrow-values">
        {{before}} ↓ <span class="is-changed">{{after}}</span>
      </div>
    </div>
  </div>

  <div class="ol-purify-consequence-box">
    <div class="ol-purify-consequence-title">{{localize "OCHO.Chat.PurifyConsequence"}}</div>
    <div class="ol-purify-consequence-text">{{consequence}}</div>
  </div>
</article>
