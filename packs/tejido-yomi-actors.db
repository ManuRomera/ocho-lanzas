{"_id":"0dc29acb657541a7","name":"Tanaka Sōsuke","img":"systems/ocho-lanzas/assets/tejido-de-yomi/portraits/sosuke.svg","folder":null,"sort":0,"ownership":{"default":0},"flags":{"ocho-lanzas":{"tejidoSlug":"npc-sosuke","tejidoDataVersion":"1.0.0","tejidoFolderKey":"npcs"}},"_stats":{"systemId":"ocho-lanzas","systemVersion":"0.3.14","coreVersion":"13.351","createdTime":1773500222223,"modifiedTime":1773500222223,"lastModifiedBy":""},"type":"npc","system":{"concept":"Mensajero atrapado en el sueño","occupation":"Agente auxiliar de Las Ocho Lanzas","curse":"Está medio tejido al tapiz y murmura desde el sueño de Yomi.","curseCount":3,"notes":"Puede revelar pistas, el nombre verdadero o el ritmo del tapiz si se logra despertarlo o escuchar sus susurros."},"prototypeToken":{"name":"Tanaka Sōsuke","actorLink":false,"texture":{"src":"systems/ocho-lanzas/assets/tejido-de-yomi/portraits/sosuke.svg","scaleX":1,"scaleY":1},"disposition":0,"displayName":40,"displayBars":0,"visionMode":"basic"},"items":[]}
