{"_id":"b56a8b93382be1f8","name":"Kanemoto Ryū","img":"systems/ocho-lanzas/assets/tejido-de-yomi/portraits/ryu.svg","folder":null,"sort":0,"ownership":{"default":0},"flags":{"ocho-lanzas":{"tejidoSlug":"actor-ryu","tejidoDataVersion":"1.0.0","tejidoFolderKey":"agents"}},"_stats":{"systemId":"ocho-lanzas","systemVersion":"0.3.14","coreVersion":"13.351","createdTime":1773500222223,"modifiedTime":1773500222223,"lastModifiedBy":""},"type":"character","system":{"concept":"Ronin · El Espejo Roto","occupation":"Samurái sin señor (Ronin)","curse":"Ve sombras con forma de su antiguo señor al borde del sueño.","curseCount":1,"backgrounds":["Soldado"],"prides":["Código"],"onmyoujis":[],"bondsText":"Protege a Shizuku aunque ella no lo pida. Mira a Mitsuru con respeto cauteloso.","eventsText":"Mató a su señor cuando la Maldición lo volvió monstruoso. Nadie le creyó salvo Las Ocho Lanzas.","equipmentText":"Katana sin vaina atada en tela negra. Ropa de viaje. Manta de campaña.","haikaText":"El miedo informa. La duda mata. La hoja recuerda.","notes":"Rasgo visible: cicatriz diagonal de ceja a barbilla. Frases: 'Ya vi esto una vez.' / 'El miedo es información.'"},"prototypeToken":{"name":"Kanemoto Ryū","actorLink":false,"texture":{"src":"systems/ocho-lanzas/assets/tejido-de-yomi/portraits/ryu.svg","scaleX":1,"scaleY":1},"disposition":0,"displayName":40,"displayBars":0,"visionMode":"basic"},"items":[{"_id":"544ce65d1dd1fc2e","name":"Katana sin vaina","img":"icons/svg/sword.svg","folder":null,"sort":0,"ownership":{"default":0},"flags":{},"_stats":{"systemId":"ocho-lanzas","systemVersion":"0.3.14","coreVersion":"13.351","createdTime":1773500222223,"modifiedTime":1773500222223,"lastModifiedBy":""},"type":"weapon","system":{"quantity":1,"equipped":true,"tags":["Ronin","Precisa"],"description":"Katana personal de Ryū."}}]}
{"_id":"c13d525f937c7e94","name":"Tsuchigumo de Yomi","img":"systems/ocho-lanzas/assets/tejido-de-yomi/portraits/tsuchigumo.svg","folder":null,"sort":0,"ownership":{"default":0},"flags":{"ocho-lanzas":{"tejidoSlug":"bakemono-tsuchigumo","tejidoDataVersion":"1.0.0","tejidoFolderKey":"bakemono"}},"_stats":{"systemId":"ocho-lanzas","systemVersion":"0.3.14","coreVersion":"13.351","createdTime":1773500222223,"modifiedTime":1773500222223,"lastModifiedBy":""},"type":"npc","system":{"concept":"Bakemono mayor · La Tejedora de Almas","occupation":"Demonio araña nacido en Yomi","curse":"No puede mantenerse en este mundo sin un ancla y un anfitrión.","curseCount":6,"notes":"Amenazas: tejer a un ser vivo al tapiz, inmovilizar con hilos, forzar tiradas de Maldición al manifestarse. Debilidades: nombre verdadero, destrucción del tapiz y anzuelo inverso."},"prototypeToken":{"name":"Tsuchigumo de Yomi","actorLink":false,"texture":{"src":"systems/ocho-lanzas/assets/tejido-de-yomi/portraits/tsuchigumo.svg","scaleX":1,"scaleY":1},"disposition":0,"displayName":40,"displayBars":0,"visionMode":"basic"},"items":[]}
{"_id":"ec18c7366e100b1e","name":"Shizuku","img":"systems/ocho-lanzas/assets/tejido-de-yomi/portraits/shizuku.svg","folder":null,"sort":0,"ownership":{"default":0},"flags":{"ocho-lanzas":{"tejidoSlug":"actor-shizuku","tejidoDataVersion":"1.0.0","tejidoFolderKey":"agents"}},"_stats":{"systemId":"ocho-lanzas","systemVersion":"0.3.14","coreVersion":"13.351","createdTime":1773500222223,"modifiedTime":1773500222223,"lastModifiedBy":""},"type":"character","system":{"concept":"Onmyōji · La Voz del Velo","occupation":"Onmyoji (divina y exorcista)","curse":"Ha sentido el borde de Yomi desde la desaparición de su maestro Hiroshi.","curseCount":3,"backgrounds":["Erudito","Investigador"],"prides":["Fe"],"onmyoujis":["Exorcizar","Espiritismo"],"bondsText":"Sabe que Ryū carga una culpa inmensa. Cree que Mitsuru escucha cosas que ella todavía no entiende.","eventsText":"Aprendió bajo Hiroshi, desaparecido hace dos años. Busca respuestas sobre Yomi en cada misión.","equipmentText":"Tablillas con escritura roja. Pincel ritual. Pañuelo blanco en la muñeca izquierda.","haikaText":"Los nombres atan. El velo tiembla. La palabra hiere.","notes":"Inteligente y analítica. El Tsuchigumo reacciona con violencia especial cuando escucha un nombre verdadero pronunciado con certeza."},"prototypeToken":{"name":"Shizuku","actorLink":false,"texture":{"src":"systems/ocho-lanzas/assets/tejido-de-yomi/portraits/shizuku.svg","scaleX":1,"scaleY":1},"disposition":0,"displayName":40,"displayBars":0,"visionMode":"basic"},"items":[{"_id":"a9b4ecc9a1b009c4","name":"Tablillas de escritura roja","img":"icons/svg/book.svg","folder":null,"sort":0,"ownership":{"default":0},"flags":{},"_stats":{"systemId":"ocho-lanzas","systemVersion":"0.3.14","coreVersion":"13.351","createdTime":1773500222223,"modifiedTime":1773500222223,"lastModifiedBy":""},"type":"ritual","system":{"quantity":1,"equipped":true,"tags":["Exorcismo","Nombre verdadero"],"description":"Foco ritual de Shizuku."}}]}
